  "J_subject_matter": {
    "type": "string",
    "required": true,
    "source_hint": "Subject Matter field or infer from content; Hazardous Tree, Tree Trimming, Fallen Tree, Grass Cutting, Surface Erosion, Others",
    "fallback": "Others"
  },
  "K_10day_rule_due_date": {
    "type": "date",
