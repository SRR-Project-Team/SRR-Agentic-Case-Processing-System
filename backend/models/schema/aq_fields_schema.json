{
  "A_date_received": {
    "type": "date",
    "format": "dd-MMM-yyyy",
    "required": true,
    "source_hint": "II. ASSIGNMENT HISTORY table, row where Status=Open AND Dept=ASD",
    "fallback": ""
  },
  "B_source": {
    "type": "string",
    "required": true,
    "source_hint": "ICC for TXT, TMO for TMO PDF, RCC for RCC PDF",
    "fallback": "ICC"
  },
  "C_case_number": {
    "type": "string",
    "required": true,
    "source_hint": "1823 Case: 3-XXXXXXXXXX, or TMO Ref., or RCC#",
    "fallback": ""
  },
  "D_type": {
    "type": "enum",
    "values": ["Emergency", "Urgent", "General"],
    "required": true,
    "source_hint": "Specific Q&A or Description; Emergency=immediate danger, Urgent=potential risk, General=no risk",
    "fallback": "General"
  },
  "E_caller_name": {
    "type": "string",
    "required": true,
    "source_hint": "VI. CONTACT INFORMATION Last Name; NA if anonymous",
    "fallback": ""
  },
  "F_contact_no": {
    "type": "string",
    "required": true,
    "source_hint": "VI. CONTACT INFORMATION Mobile/Email; NA if anonymous",
    "fallback": ""
  },
  "G_slope_no": {
    "type": "string",
    "pattern": "^\\d{1,2}[A-Za-z]{2,3}[-/][A-Za-z0-9/()\\-]+$",
